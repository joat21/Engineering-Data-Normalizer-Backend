generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique
  passwordHash String
  name         String
  comparison   Comparison?
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  description String
  isArchived  Boolean       @default(false)
  items       ProjectItem[]
}

model ProjectItem {
  id          String    @id @default(uuid()) @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String    @db.Uuid
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId String    @db.Uuid
  amount      Int       @db.SmallInt
  updatedAt   DateTime  @default(now()) @db.Timestamptz()

  @@unique([projectId, equipmentId])
}

model Equipment {
  id               String                    @id @default(uuid()) @db.Uuid
  category         Category                  @relation(fields: [categoryId], references: [id])
  categoryId       String                    @db.Uuid
  source           Source                    @relation(fields: [sourceId], references: [id])
  sourceId         String                    @db.Uuid
  searchText       String?                   @db.Text
  name             String?
  manufacturerName String?
  supplierName     String?
  article          String?
  model            String?
  externalCode     String?
  priceInRub       Decimal                   @db.Decimal(12, 2)
  price            Decimal                   @db.Decimal(12, 2)
  projectItems     ProjectItem[]
  attributes       EquipmentAttributeValue[]
  comparisonItems  ComparisonItem[]
  manufacturer     Manufacturer?             @relation(fields: [manufacturerId], references: [id])
  manufacturerId   String?                   @db.Uuid
  supplier         Supplier?                 @relation(fields: [supplierId], references: [id])
  supplierId       String?                   @db.Uuid
  currency         Currency?                 @relation(fields: [currencyId], references: [id])
  currencyId       String?                   @db.Uuid
  search_vector    Unsupported("tsvector")?  @default(dbgenerated())

  @@index([search_vector], name: "equipment_search_idx", type: Gin)
}

model EquipmentAttributeValue {
  id           String            @id @default(uuid()) @db.Uuid
  equipment    Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentId  String            @db.Uuid
  attribute    CategoryAttribute @relation(fields: [attributeId], references: [id])
  attributeId  String            @db.Uuid
  valueString  String
  valueMin     Decimal?          @db.Decimal(12, 2)
  valueMax     Decimal?          @db.Decimal(12, 2)
  valueArray   Json?
  valueBoolean Boolean?

  @@index([attributeId, valueString])
  @@index([attributeId, valueMin, valueMax])
}

model Category {
  id             String              @id @default(uuid()) @db.Uuid
  name           String
  equipment      Equipment[]
  attributes     CategoryAttribute[]
  importSessions ImportSession[]
  filters        CategoryFilter[]
}

model CategoryAttribute {
  id                       String                    @id @default(uuid()) @db.Uuid
  category                 Category                  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId               String                    @db.Uuid
  key                      String
  label                    String
  unit                     String
  dataType                 DataType
  isFilterable             Boolean
  filters                  CategoryFilter[]
  equipmentAttributeValues EquipmentAttributeValue[]
  normalizationCaches      NormalizationCache[]
}

model CategoryFilter {
  id          String             @id @default(uuid()) @db.Uuid
  category    Category           @relation(fields: [categoryId], references: [id])
  categoryId  String             @db.Uuid
  attribute   CategoryAttribute? @relation(fields: [attributeId], references: [id])
  attributeId String?            @db.Uuid
  systemField String?
  label       String
  unit        String?
  type        DataType
  minValue    Decimal?           @db.Decimal(12, 2)
  maxValue    Decimal?           @db.Decimal(12, 2)
  options     Json?

  @@unique([categoryId, attributeId])
  @@unique([categoryId, systemField])
}

model Source {
  id             String          @id @default(uuid()) @db.Uuid
  fileName       String
  url            String
  uploadedAt     DateTime        @default(now()) @db.Timestamptz()
  type           SourceType
  fileHash       String          @unique
  equipment      Equipment[]
  importSessions ImportSession[]
  manufacturer   Manufacturer?   @relation(fields: [manufacturerId], references: [id])
  manufacturerId String?         @db.Uuid
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  supplierId     String?         @db.Uuid
}

model Comparison {
  id     String           @id @default(uuid()) @db.Uuid
  user   User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?          @unique @db.Uuid
  items  ComparisonItem[]
}

model ComparisonItem {
  id           String     @id @default(uuid()) @db.Uuid
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  comparisonId String     @db.Uuid
  equipment    Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentId  String     @db.Uuid

  @@unique([comparisonId, equipmentId])
}

model ImportSession {
  id              String              @id @default(uuid()) @db.Uuid
  source          Source              @relation(fields: [sourceId], references: [id])
  sourceId        String              @db.Uuid
  category        Category            @relation(fields: [categoryId], references: [id])
  categoryId      String              @db.Uuid
  createdAt       DateTime            @default(now()) @db.Timestamptz()
  status          ImportStatus        @default(PENDING)
  originHeader    Json?               @default("[]")
  manufacturer    Manufacturer?       @relation(fields: [manufacturerId], references: [id])
  manufacturerId  String?             @db.Uuid
  supplier        Supplier?           @relation(fields: [supplierId], references: [id])
  supplierId      String?             @db.Uuid
  currency        Currency?           @relation(fields: [currencyId], references: [id])
  currencyId      String?             @db.Uuid
  items           StagingImportItem[]
  aiParseSessions AiParseSession[]
}

model StagingImportItem {
  id             String           @id @default(uuid()) @db.Uuid
  session        ImportSession    @relation(fields: [sessionId], references: [id])
  sessionId      String           @db.Uuid
  rowIndex       Int
  rawRow         Json
  transformedRow Json?
  status         ImportItemStatus @default(PENDING)
  aiParseResults AiParseResult[]

  @@index([rowIndex])
}

model NormalizationCache {
  id           String            @id @default(uuid()) @db.Uuid
  attribute    CategoryAttribute @relation(fields: [attributeId], references: [id])
  attributeId  String            @db.Uuid
  cleanedValue String
  rawValue     String
  normalized   Json

  @@unique([attributeId, cleanedValue])
  @@index([cleanedValue])
}

model AiParseSession {
  id              String          @id @default(uuid()) @db.Uuid
  importSession   ImportSession   @relation(fields: [importSessionId], references: [id])
  importSessionId String          @db.Uuid
  createdAt       DateTime        @default(now()) @db.Timestamptz()
  aiParseResults  AiParseResult[]
}

model AiParseResult {
  id             String            @id @default(uuid()) @db.Uuid
  aiParseSession AiParseSession    @relation(fields: [sessionId], references: [id])
  sessionId      String            @db.Uuid
  sourceItem     StagingImportItem @relation(fields: [sourceItemId], references: [id])
  sourceItemId   String            @db.Uuid
  targetType     MappingTargetType
  targetKey      String
  rawValue       String

  @@unique([sessionId, sourceItemId, targetKey])
}

model Manufacturer {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @unique
  equipment      Equipment[]
  sources        Source[]
  importSessions ImportSession[]
}

model Supplier {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @unique
  equipment      Equipment[]
  sources        Source[]
  importSessions ImportSession[]
}

model Currency {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  code           String          @unique
  symbol         String
  rate           Decimal         @db.Decimal(14, 4)
  updatedAt      DateTime        @updatedAt @db.Timestamptz()
  equipment      Equipment[]
  importSessions ImportSession[]
}

enum DataType {
  STRING
  NUMBER
  BOOLEAN
}

enum SourceType {
  CATALOG
  SINGLE_ITEM
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ImportItemStatus {
  PENDING
  TRANSFORMED
  EDITED_MANUALLY
}

enum MappingTargetType {
  SYSTEM
  ATTRIBUTE
}
