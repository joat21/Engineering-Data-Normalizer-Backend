generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique
  passwordHash String
  name         String
  comparison   Comparison?
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  description String
  isArchived  Boolean       @default(false)
  items       ProjectItem[]
}

model ProjectItem {
  id          String    @id @default(uuid()) @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String    @db.Uuid
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId String    @db.Uuid
  amount      Int       @db.SmallInt
  updatedAt   DateTime  @default(now()) @db.Timestamptz()

  @@unique([projectId, equipmentId])
}

model Equipment {
  id              String                    @id @default(uuid()) @db.Uuid
  category        Category                  @relation(fields: [categoryId], references: [id])
  categoryId      String                    @db.Uuid
  source          Source                    @relation(fields: [sourceId], references: [id])
  sourceId        String                    @db.Uuid
  name            String?
  manufacturer    String?
  article         String?
  model           String?
  externalCode    String?
  price           Decimal                   @db.Decimal(12, 2)
  projectItems    ProjectItem[]
  attributes      EquipmentAttributeValue[]
  comparisonItems ComparisonItem[]
}

model EquipmentAttributeValue {
  id           String            @id @default(uuid()) @db.Uuid
  equipment    Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentId  String            @db.Uuid
  attribute    CategoryAttribute @relation(fields: [attributeId], references: [id])
  attributeId  String            @db.Uuid
  valueString  String
  valueMin     Decimal?          @db.Decimal(12, 2)
  valueMax     Decimal?          @db.Decimal(12, 2)
  valueArray   Json?
  valueBoolean Boolean?
}

model Category {
  id             String              @id @default(uuid()) @db.Uuid
  name           String
  equipment      Equipment[]
  attributes     CategoryAttribute[]
  importSessions ImportSession[]
  filters        CategoryFilter[]
}

model CategoryAttribute {
  id                       String                    @id @default(uuid()) @db.Uuid
  category                 Category                  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId               String                    @db.Uuid
  key                      String
  label                    String
  unit                     String
  dataType                 DataType
  isFilterable             Boolean
  filters                  CategoryFilter[]
  equipmentAttributeValues EquipmentAttributeValue[]
}

model CategoryFilter {
  id          String             @id @default(uuid()) @db.Uuid
  category    Category           @relation(fields: [categoryId], references: [id])
  categoryId  String             @db.Uuid
  attribute   CategoryAttribute? @relation(fields: [attributeId], references: [id])
  attributeId String?            @db.Uuid
  systemField String?
  label       String
  type        DataType
  minValue    Decimal?           @db.Decimal(12, 2)
  maxValue    Decimal?           @db.Decimal(12, 2)
  options     Json?

  @@unique([categoryId, attributeId])
  @@unique([categoryId, systemField])
}

model Source {
  id             String          @id @default(uuid()) @db.Uuid
  fileName       String
  url            String
  uploadedAt     DateTime        @default(now()) @db.Timestamptz()
  type           SourceType
  fileHash       String          @unique
  equipment      Equipment[]
  importSessions ImportSession[]
}

model Comparison {
  id     String           @id @default(uuid()) @db.Uuid
  user   User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?          @unique @db.Uuid
  items  ComparisonItem[]
}

model ComparisonItem {
  id           String     @id @default(uuid()) @db.Uuid
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  comparisonId String     @db.Uuid
  equipment    Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentId  String     @db.Uuid

  @@unique([comparisonId, equipmentId])
}

model ImportSession {
  id              String              @id @default(uuid()) @db.Uuid
  source          Source              @relation(fields: [sourceId], references: [id])
  sourceId        String              @db.Uuid
  category        Category            @relation(fields: [categoryId], references: [id])
  categoryId      String              @db.Uuid
  createdAt       DateTime            @default(now()) @db.Timestamptz()
  status          ImportStatus        @default(PENDING)
  originHeader    Json?               @default("[]")
  items           StagingImportItem[]
  aiParseSessions AiParseSession[]
}

model StagingImportItem {
  id             String           @id @default(uuid()) @db.Uuid
  session        ImportSession    @relation(fields: [sessionId], references: [id])
  sessionId      String           @db.Uuid
  rowIndex       Int
  rawRow         Json
  transformedRow Json?
  status         ImportItemStatus @default(PENDING)
  aiParseResults AiParseResult[]

  @@index([rowIndex])
}

model NormalizationCache {
  id           String @id @default(uuid()) @db.Uuid
  attributeId  String @db.Uuid
  cleanedValue String
  rawValue     String
  normalized   Json

  @@unique([attributeId, cleanedValue])
  @@index([cleanedValue])
}

model AiParseSession {
  id              String          @id @default(uuid()) @db.Uuid
  importSession   ImportSession   @relation(fields: [importSessionId], references: [id])
  importSessionId String          @db.Uuid
  createdAt       DateTime        @default(now()) @db.Timestamptz()
  aiParseResults  AiParseResult[]
}

model AiParseResult {
  id             String            @id @default(uuid()) @db.Uuid
  aiParseSession AiParseSession    @relation(fields: [sessionId], references: [id])
  sessionId      String            @db.Uuid
  sourceItem     StagingImportItem @relation(fields: [sourceItemId], references: [id])
  sourceItemId   String            @db.Uuid
  targetType     MappingTargetType
  targetKey      String
  rawValue       String

  @@unique([sessionId, sourceItemId, targetKey])
}

enum DataType {
  STRING
  NUMBER
  BOOLEAN
}

enum SourceType {
  CATALOG
  SINGLE_ITEM
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ImportItemStatus {
  PENDING
  TRANSFORMED
  EDITED_MANUALLY
}

enum MappingTargetType {
  SYSTEM
  ATTRIBUTE
}
